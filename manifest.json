<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BuddyRunner | Campus OS</title>
    <link rel="manifest" href="manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="BuddyRunner">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/726/726048.png">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>

    <style>
        :root { 
            --primary: #FF8C00; 
            --primary-glow: rgba(255, 140, 0, 0.3);
            --navy: #0A1120; 
            --card-navy: rgba(22, 28, 45, 0.95); 
            --white: #FFFFFF; 
            --txt-dim: #94A3B8; 
            --success: #10B981; 
            --danger: #EF4444; 
            --info: #3B82F6;
            --runner-bg: linear-gradient(145deg, rgba(255,140,0,0.1) 0%, rgba(10,17,32,0.95) 100%);
            --requester-bg: linear-gradient(145deg, rgba(59,130,246,0.1) 0%, rgba(10,17,32,0.95) 100%);
        }
        
        * { box-sizing: border-box; margin: 0; padding: 0; outline: none; -webkit-tap-highlight-color: transparent; }
        
        body { 
            font-family: 'Outfit', sans-serif; 
            background: linear-gradient(rgba(10, 17, 32, 0.85), rgba(10, 17, 32, 0.85)), url('https://images.unsplash.com/photo-1523050335392-93851179ae22?auto=format&fit=crop&w=1000&q=80');
            background-size: cover;
            background-attachment: fixed;
            color: var(--white); 
            padding-bottom: 140px; 
            overflow-x: hidden; 
            transition: background 0.3s ease;
        }
        
        body.runner-mode {
            background: linear-gradient(rgba(255, 140, 0, 0.15), rgba(10, 17, 32, 0.95)), url('https://images.unsplash.com/photo-1523050335392-93851179ae22?auto=format&fit=crop&w=1000&q=80');
        }
        
        #registration-screen { 
            position: fixed; 
            inset: 0; 
            background: radial-gradient(circle at center, #161C2D 0%, #0A1120 100%); 
            z-index: 9999; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            padding: 20px; 
        }
        
        .reg-card { 
            background: var(--card-navy); 
            padding: 40px 30px; 
            border-radius: 32px; 
            width: 100%; 
            max-width: 400px; 
            text-align: center; 
            border: 1px solid rgba(255,255,255,0.05); 
            box-shadow: 0 20px 50px rgba(0,0,0,0.3); 
            backdrop-filter: blur(10px); 
        }
        
        .text-logo { 
            font-size: 2.5rem; 
            font-weight: 800; 
            margin-bottom: 15px; 
            letter-spacing: -1.5px; 
            color: var(--white); 
            animation: float 3s ease-in-out infinite; 
        }
        
        .text-logo span { 
            color: var(--primary); 
            text-shadow: 0 0 20px var(--primary-glow);
        }
        
        @keyframes float { 
            0%, 100% { transform: translateY(0); } 
            50% { transform: translateY(-10px); } 
        }

        .container { 
            max-width: 450px; 
            margin: 0 auto; 
            padding: 1.2rem; 
        }
        
        header { 
            padding: 1rem 1.2rem; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            position: sticky; 
            top: 0; 
            z-index: 1001; 
            background: rgba(10, 17, 32, 0.95); 
            backdrop-filter: blur(12px); 
            border-bottom: 1px solid rgba(255,255,255,0.05); 
        }
        
        .header-group { 
            display: flex; 
            align-items: center; 
            gap: 6px; 
            flex-shrink: 0; 
        }

        .tab-nav { 
            background: rgba(255,255,255,0.05); 
            padding: 5px; 
            border-radius: 20px; 
            display: flex; 
            position: relative; 
            margin-bottom: 1.5rem; 
            backdrop-filter: blur(5px); 
        }
        
        .tab-btn { 
            flex: 1; 
            padding: 12px; 
            text-align: center; 
            font-weight: 800; 
            cursor: pointer; 
            z-index: 2; 
            color: var(--txt-dim); 
            font-size: 0.85rem; 
            transition: color 0.3s ease;
        }
        
        .tab-btn.active { 
            color: var(--white); 
        }
        
        .glider { 
            position: absolute; 
            height: calc(100% - 10px); 
            width: calc(50% - 5px); 
            background: var(--primary); 
            border-radius: 16px; 
            top: 5px; 
            left: 5px; 
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        }
        
        .glass-card { 
            background: var(--card-navy); 
            padding: 25px; 
            border-radius: 28px; 
            margin-bottom: 20px; 
            border: 1px solid rgba(255,255,255,0.03); 
            backdrop-filter: blur(10px); 
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .glass-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.4);
        }
        
        label { 
            display: block; 
            font-size: 0.7rem; 
            font-weight: 800; 
            text-transform: uppercase; 
            color: var(--txt-dim); 
            margin: 0 0 8px 5px; 
            letter-spacing: 1px; 
        }
        
        select, input { 
            width: 100%; 
            padding: 16px; 
            background: rgba(0,0,0,0.3); 
            border: 1px solid rgba(255,255,255,0.1); 
            border-radius: 18px; 
            color: var(--white); 
            margin-bottom: 15px; 
            font-family: inherit; 
            transition: border-color 0.2s ease;
        }
        
        select:focus, input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 2px var(--primary-glow);
        }
        
        .category-grid { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 10px; 
            margin-bottom: 20px; 
        }
        
        .cat-item { 
            background: rgba(255,255,255,0.03); 
            border-radius: 20px; 
            padding: 15px 5px; 
            text-align: center; 
            cursor: pointer; 
            border: 1px solid transparent; 
            transition: all 0.2s ease; 
        }
        
        .cat-item:hover {
            background: rgba(255, 140, 0, 0.1); 
            border-color: var(--primary);
            transform: scale(1.02);
        }
        
        .cat-item:active { 
            transform: scale(0.98);
        }

        /* Karma Level Colors */
        .lvl-newbie { color: #94A3B8; }
        .lvl-pro { color: #3B82F6; }
        .lvl-legend { 
            color: #FF8C00; 
            text-shadow: 0 0 10px rgba(255,140,0,0.5);
            animation: legendGlow 2s ease-in-out infinite;
        }

        @keyframes legendGlow {
            0%, 100% { text-shadow: 0 0 10px rgba(255,140,0,0.5); }
            50% { text-shadow: 0 0 20px rgba(255,140,0,0.8); }
        }

        .reward-pill {
            background: rgba(255, 140, 0, 0.15);
            color: var(--primary);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 800;
            display: inline-block;
            margin-bottom: 10px;
            border: 1px solid rgba(255,140,0,0.3);
            backdrop-filter: blur(5px);
        }

        .karma-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 800;
            margin-left: 8px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .active-user-card {
            background: linear-gradient(145deg, rgba(255,140,0,0.1), rgba(22,28,45,0.95));
            border: 1px solid rgba(255,140,0,0.3);
            border-radius: 20px;
            padding: 15px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 15px;
            transition: all 0.2s ease;
        }

        .active-user-card:hover {
            transform: translateX(5px);
            border-color: var(--primary);
        }

        .active-user-avatar {
            width: 50px;
            height: 50px;
            background: linear-gradient(145deg, var(--primary), #FFB347);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: 800;
            box-shadow: 0 5px 15px rgba(255,140,0,0.3);
        }

        .active-user-info {
            flex: 1;
        }

        .active-user-name {
            font-weight: 800;
            font-size: 1rem;
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 5px;
        }

        .active-user-status {
            font-size: 0.7rem;
            color: var(--success);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            display: inline-block;
            animation: pulse 2s infinite;
            box-shadow: 0 0 10px var(--success);
        }

        @keyframes pulse {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.2); }
            100% { opacity: 1; transform: scale(1); }
        }

        .mode-badge {
            background: rgba(255,255,255,0.15);
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 800;
            color: var(--primary);
            border: 1px solid var(--primary);
            animation: badgePulse 2s infinite;
        }

        @keyframes badgePulse {
            0%, 100% { box-shadow: 0 0 10px var(--primary-glow); }
            50% { box-shadow: 0 0 20px var(--primary-glow); }
        }

        .btn-main { 
            width: 100%; 
            padding: 18px; 
            border: none; 
            border-radius: 20px; 
            background: linear-gradient(145deg, var(--primary), #FFB347); 
            color: white; 
            font-weight: 800; 
            cursor: pointer; 
            transition: all 0.3s ease; 
            font-size: 1rem; 
            box-shadow: 0 10px 20px rgba(255, 140, 0, 0.3); 
            position: relative;
            overflow: hidden;
        }

        .btn-main::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s ease;
        }

        .btn-main:hover::before {
            left: 100%;
        }

        .btn-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(255, 140, 0, 0.4);
        }

        .btn-success { 
            background: linear-gradient(145deg, var(--success), #34D399); 
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3); 
        }
        
        .btn-action-row { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 10px; 
            margin-top: 15px; 
        }
        
        .btn-small { 
            padding: 12px; 
            border-radius: 15px; 
            border: none; 
            font-weight: 800; 
            font-size: 0.75rem; 
            cursor: pointer; 
            transition: all 0.2s ease; 
            text-align: center; 
            text-decoration: none; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            gap: 8px;
        }

        .btn-small:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
        }
        
        .btn-cancel { 
            background: rgba(239, 68, 68, 0.15); 
            color: var(--danger); 
            border: 1px solid rgba(239, 68, 68, 0.3); 
        }
        
        .btn-chat { 
            background: linear-gradient(145deg, var(--info), #60A5FA); 
            color: white; 
        }

        .btn-track {
            background: rgba(255, 140, 0, 0.15);
            color: var(--primary);
            border: 1px solid var(--primary);
            padding: 10px;
            border-radius: 12px;
            text-decoration: none;
            display: inline-block;
            width: 100%;
            text-align: center;
            font-weight: 800;
            font-size: 0.8rem;
            transition: all 0.2s ease;
        }

        .btn-track:hover {
            background: var(--primary);
            color: white;
        }

        .mission-card { 
            background: var(--card-navy); 
            padding: 1.5rem; 
            border-radius: 28px; 
            margin-bottom: 1rem; 
            border: 1px solid rgba(255,255,255,0.03); 
            backdrop-filter: blur(10px); 
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .mission-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), transparent);
        }

        .mission-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }
        
        .pill { 
            font-size: 0.65rem; 
            font-weight: 900; 
            padding: 5px 12px; 
            border-radius: 10px; 
            background: rgba(255, 140, 0, 0.15); 
            color: var(--primary); 
            display: inline-block; 
            margin-bottom: 12px; 
            border: 1px solid rgba(255,140,0,0.3);
        }
        
        .secure-box { 
            background: rgba(16, 185, 129, 0.1); 
            border: 1px solid var(--success); 
            padding: 18px; 
            border-radius: 20px; 
            margin-top: 15px; 
            text-align: center; 
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
        }
        
        .bottom-bar { 
            position: fixed; 
            bottom: 20px; 
            left: 50%; 
            transform: translateX(-50%); 
            width: 92%; 
            background: linear-gradient(145deg, var(--primary), #FFB347); 
            padding: 1rem 1.5rem; 
            border-radius: 30px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            z-index: 1000; 
            box-shadow: 0 10px 30px rgba(255,140,0,0.4); 
            border: 1px solid rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
        }
        
        .mode-info { 
            display: flex; 
            flex-direction: column; 
        }
        
        .mode-title { 
            font-size: 1rem; 
            font-weight: 800; 
            display: flex; 
            align-items: center; 
            gap: 8px; 
        }
        
        .mode-subtitle { 
            font-size: 0.7rem; 
            color: rgba(255,255,255,0.9); 
            margin-top: 2px; 
        }
        
        .toggle-switch { 
            width: 60px; 
            height: 34px; 
            background: rgba(0,0,0,0.3); 
            border-radius: 30px; 
            position: relative; 
            cursor: pointer; 
            border: 2px solid rgba(255,255,255,0.3); 
            transition: background 0.3s ease;
        }
        
        .toggle-circle { 
            width: 26px; 
            height: 26px; 
            background: white; 
            border-radius: 50%; 
            position: absolute; 
            top: 2px; 
            left: 2px; 
            transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        
        .active-toggle .toggle-circle { 
            transform: translateX(26px); 
            background: var(--primary);
        }
        
        .logout-btn { 
            background: rgba(239, 68, 68, 0.2); 
            color: var(--danger); 
            border: 1px solid rgba(239, 68, 68, 0.3); 
            padding: 8px 12px; 
            border-radius: 12px; 
            font-weight: 800; 
            font-size: 0.7rem; 
            cursor: pointer; 
            transition: all 0.2s ease;
        }

        .logout-btn:hover {
            background: var(--danger);
            color: white;
        }

        #chat-overlay { 
            position: fixed; 
            inset: 0; 
            background: var(--navy); 
            z-index: 2005; 
            display: none; 
            flex-direction: column; 
            height: 100vh; 
        }
        
        .chat-header { 
            padding: 1.2rem; 
            background: var(--card-navy); 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            border-bottom: 1px solid rgba(255,255,255,0.05); 
        }
        
        #chat-messages { 
            flex: 1; 
            overflow-y: auto; 
            padding: 1.5rem; 
            display: flex; 
            flex-direction: column; 
            gap: 12px; 
            background-size: cover; 
            background-position: center; 
            transition: 0.4s ease-in-out; 
        }
        
        .msg { 
            padding: 12px 18px; 
            border-radius: 20px; 
            max-width: 80%; 
            font-size: 0.9rem; 
            line-height: 1.4; 
            word-wrap: break-word; 
            animation: messageIn 0.3s ease;
        }

        @keyframes messageIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .msg-me { 
            align-self: flex-end; 
            background: linear-gradient(145deg, var(--primary), #FFB347); 
            color: white; 
            border-bottom-right-radius: 4px; 
        }
        
        .msg-them { 
            align-self: flex-start; 
            background: var(--card-navy); 
            color: var(--white); 
            border-bottom-left-radius: 4px; 
            border: 1px solid rgba(255,255,255,0.05); 
        }
        
        .chat-input-box { 
            padding: 1rem; 
            background: var(--card-navy); 
            border-top: 1px solid rgba(255,255,255,0.05); 
        }
        
        #chat-input { 
            flex: 1; 
            padding: 14px 20px; 
            background: rgba(0,0,0,0.3); 
            border: 1px solid rgba(255,255,255,0.1); 
            border-radius: 30px; 
            color: white; 
            margin-bottom: 0; 
            font-size: 0.95rem;
        }
        
        .chat-send { 
            background: linear-gradient(145deg, var(--primary), #FFB347); 
            border: none; 
            width: 50px; 
            height: 50px; 
            border-radius: 50%; 
            color: white; 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 1.2rem;
            transition: all 0.2s ease;
            box-shadow: 0 5px 15px rgba(255,140,0,0.3);
        }

        .chat-send:hover {
            transform: scale(1.1);
        }

        .sticker {
            background: rgba(255,255,255,0.05);
            padding: 10px 15px;
            border-radius: 25px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 1px solid rgba(255,255,255,0.1);
            white-space: nowrap;
        }

        .sticker:hover {
            background: var(--primary);
            transform: scale(1.05);
        }

        #platform-notification { 
            position: fixed; 
            top: -100px; 
            left: 5%; 
            width: 90%; 
            background: var(--card-navy); 
            border: 2px solid var(--primary); 
            border-radius: 20px; 
            padding: 15px; 
            z-index: 3000; 
            box-shadow: 0 10px 30px rgba(255,140,0,0.3); 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            backdrop-filter: blur(10px);
        }
        
        #platform-notification.show { 
            top: 20px; 
        }

        .stats-card {
            background: linear-gradient(145deg, rgba(255,140,0,0.1), rgba(22,28,45,0.95));
            border-radius: 20px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-around;
            border: 1px solid rgba(255,140,0,0.3);
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--primary);
        }

        .stat-label {
            font-size: 0.7rem;
            color: var(--txt-dim);
            text-transform: uppercase;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255,255,255,0.3);
            font-size: 1rem;
            background: rgba(255,255,255,0.02);
            border-radius: 30px;
            border: 2px dashed rgba(255,255,255,0.1);
        }

        .empty-state-emoji {
            font-size: 3rem;
            margin-bottom: 15px;
            animation: float 3s ease-in-out infinite;
        }
    </style>
</head>
<body>

<div id="platform-notification" onclick="this.classList.remove('show')">
    <div style="background:var(--primary); width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem;">💬</div>
    <div>
        <div style="font-weight: 800; font-size: 0.7rem; color: var(--primary);">NEW MESSAGE</div>
        <div id="notif-text" style="font-size: 0.85rem; color: white;">...</div>
    </div>
</div>

<div id="registration-screen">
    <div class="reg-card">
        <div class="text-logo">Buddy<span>Runner</span></div>
        <p style="font-size: 1rem; color: var(--white); font-weight: 600; margin-bottom: 5px;">Exclusive radar for IMT Hyderabad.</p>
        <p style="font-size: 0.85rem; color: var(--txt-dim); margin-bottom: 25px;">Hostel life, sorted.</p>
        <div style="text-align: left;">
            <label>Display Name</label>
            <input type="text" id="u-name" placeholder="e.g. KAKA RAO👺">
            <label>Mobile Number</label>
            <input type="tel" id="u-phone" maxlength="10" placeholder="10-digit number">
        </div>
        <button onclick="saveUser()" class="btn-main">Enter Radar</button>
    </div>
</div>

<div class="container" id="app-body" style="display:none;">
    <header>
        <div style="font-weight: 800; font-size: 1.1rem; flex-shrink: 1;" class="text-logo">Buddy<span>Runner</span></div>
        <div class="header-group">
            <button onclick="enableNotifications()" style="background:none; border:none; font-size:1.1rem; cursor:pointer; padding: 5px; border-radius: 8px;">🔔</button>
            <a href="https://docs.google.com/forms/d/e/1FAIpQLScN2j1rEhMBBlh28jWtbkvazL0zUZQ7y3otBTkROAmkfzQDKA/viewform?usp=sf_link" target="_blank" style="text-decoration:none; font-size:0.6rem; font-weight:800; color:var(--white); background: var(--info); padding: 6px 10px; border-radius: 8px; white-space: nowrap;">Feedback</a>
            <div id="u-display" style="font-size:0.6rem; font-weight:800; color:var(--primary); background: rgba(255, 140, 0, 0.1); padding: 6px 10px; border-radius: 8px; max-width: 60px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"></div>
            <button onclick="logout()" class="logout-btn">Exit</button>
        </div>
    </header>
    
    <!-- Stats Card -->
    <div id="stats-card" class="stats-card" style="display: none;">
        <div class="stat-item">
            <div class="stat-value" id="karma-count">0</div>
            <div class="stat-label">Karma Points</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="helps-count">0</div>
            <div class="stat-label">People Helped</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="rank-badge">🌱</div>
            <div class="stat-label">Rank</div>
        </div>
    </div>
    
    <!-- Only show tabs and form when in Requester Mode -->
    <div id="requester-section" style="display: block;">
        <div class="tab-nav">
            <div class="glider" id="glider"></div>
            <div class="tab-btn active" onclick="setTab('errand', 0)">Errands</div>
            <div class="tab-btn" onclick="setTab('ride', 100)">Cab Share</div>
        </div>
        <div class="glass-card" id="form-content"></div>
    </div>
    
    <!-- Show "Going Out" header when in Runner Mode -->
    <div id="runner-header" style="display: none; margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 15px; background: linear-gradient(145deg, rgba(255,140,0,0.1), rgba(22,28,45,0.95)); padding: 20px; border-radius: 28px; border: 1px solid var(--primary);">
            <span style="font-size: 2.5rem; animation: float 3s ease-in-out infinite;">🛵</span>
            <div>
                <h2 style="font-size: 1.4rem; font-weight: 800; margin-bottom: 5px;">Going Out Mode</h2>
                <p style="font-size: 0.85rem; color: var(--txt-dim);">You're available to help others! Browse requests below.</p>
            </div>
            <span class="mode-badge" style="margin-left: auto;">ACTIVE</span>
        </div>
    </div>
    
    <h3 id="radar-title" style="margin-bottom:15px; font-weight:800; color: var(--txt-dim); font-size: 0.75rem; letter-spacing: 1px; display: flex; align-items: center; gap: 8px;">
        <span id="feed-title">ACTIVE REQUESTS</span>
        <span id="active-users-title" style="display: none;">PEOPLE GOING OUT NOW</span>
        <span id="request-count" style="background: var(--primary); padding: 2px 8px; border-radius: 10px; font-size: 0.65rem;">0</span>
    </h3>
    
    <div id="mission-feed"></div>
    <div id="active-users-feed" style="display: none;"></div>
</div>

<div id="chat-overlay">
    <div class="chat-header">
        <div style="display: flex; align-items: center; gap: 10px;">
            <div style="width: 10px; height: 10px; background: var(--success); border-radius: 50%; animation: pulse 2s infinite;"></div>
            <div style="font-weight: 800; font-size: 1.2rem; letter-spacing: -0.5px;">BuddyChat</div>
        </div>
        <div style="display: flex; gap: 8px; align-items: center;">
            <a id="call-btn" href="tel:" style="text-decoration:none; font-size:1.2rem; background: rgba(255,255,255,0.1); padding: 8px; border-radius: 50%;">📞</a>
            <button onclick="syncWallpaper()" style="background:var(--info); border:none; color:white; padding: 8px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 800; cursor: pointer;">🎨 Theme</button>
            <button onclick="sendNudge()" style="background:rgba(255,140,0,0.2); border:1px solid var(--primary); color:var(--primary); font-weight:800; padding: 8px 12px; border-radius: 20px; font-size: 0.7rem; cursor: pointer;">🔔 Nudge</button>
            <button onclick="closeChat()" style="background:none; border:none; color:var(--danger); font-weight:800; cursor:pointer; font-size: 0.9rem;">✕</button>
        </div>
    </div>
    <div id="chat-messages"></div>
    <div class="chat-input-box">
        <div class="sticker-row" style="display:flex; gap:8px; overflow-x:auto; margin-bottom:10px; padding-bottom: 5px;">
            <div class="sticker" onclick="sendMessage('Abbey Jaldi Aa! 🐢')">🐢 Jaldi Aa</div>
            <div class="sticker" onclick="sendMessage('Oye! Kahan reh gaya? 👺')">👺 Kahan h?</div>
            <div class="sticker" onclick="sendMessage('Pakad liya! 🎯')">🎯 Pakad liya</div>
            <div class="sticker" onclick="sendMessage('5 min mein pahunch raha 🏃')">🏃 5 min</div>
            <div class="sticker" onclick="sendMessage('Bhai please jaldi 🙏')">🙏 Jaldi</div>
        </div>
        <div style="display:flex; gap:10px;">
            <input type="text" id="chat-input" placeholder="Type a message..." autocomplete="off">
            <button class="chat-send" onclick="sendMessage()">➔</button>
        </div>
    </div>
</div>

<div class="bottom-bar" id="mode-bar" style="display:none;">
    <div class="mode-info">
        <div class="mode-title">
            <span id="mode-icon">🙋</span>
            <span id="m-status">Requester Mode</span>
        </div>
        <div class="mode-subtitle" id="mode-description">Ask for help with tasks</div>
    </div>
    <div class="toggle-switch" id="role-switch" onclick="toggleRole()">
        <div class="toggle-circle"></div>
    </div>
</div>

<script>
    // Service Worker Registration
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/BuddyRunner/service-worker.js').catch(error => {
                console.log('ServiceWorker registration failed:', error);
            });
        });
    }

    const firebaseConfig = { 
        apiKey: "AIzaSyA55HET0ef3Iw--y0vLpkK4tMOvyl44jGw", 
        authDomain: "buddyrunner-1f4f4.firebaseapp.com", 
        projectId: "buddyrunner-1f4f4", 
        storageBucket: "buddyrunner-1f4f4.firebasestorage.app", 
        messagingSenderId: "441349525593", 
        appId: "1:441349525593:web:2b4429b55dc756130ae148" 
    };
    
    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();
    
    let currentUser = "", currentUserPhone = "", isRunner = false, currentTab = 'errand', database = [];
    let handledMatches = new Set();
    let currentChatId = null;
    let chatListener = null;
    let activeUsers = [];
    
    // Track user karma counts (helps completed)
    let userKarmaCounts = {};
    let currentUserKarma = 0;
    
    const wallpapers = [
        'none',
        'url("https://images.unsplash.com/photo-1541450805268-4822a3a774ca?q=80&w=1000")',
        'url("https://images.unsplash.com/photo-1534030347209-467a5b0ad3e6?q=80&w=1000")',
        'url("https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=1000")'
    ];

    window.onload = () => {
        const storedPhone = localStorage.getItem('buddyRunnerPhone');
        const storedName = localStorage.getItem('buddyRunnerName');
        if (storedPhone) { 
            currentUserPhone = storedPhone; 
            currentUser = storedName || "KAKA RAO👺"; 
            showApp(); 
        }
        loadKarmaCounts();
        checkAndShowInstallPrompt();
        setInterval(updateUserActiveStatus, 60000);
    };

    function checkAndShowInstallPrompt() {
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
        const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
        
        if (!isStandalone && !localStorage.getItem('installPromptShown')) {
            setTimeout(() => {
                const promptDiv = document.createElement('div');
                promptDiv.style.cssText = `
                    position: fixed;
                    bottom: 100px;
                    left: 10px;
                    right: 10px;
                    background: var(--card-navy);
                    padding: 20px;
                    border-radius: 20px;
                    border: 2px solid var(--primary);
                    z-index: 10000;
                    text-align: center;
                    backdrop-filter: blur(10px);
                `;
                promptDiv.innerHTML = `
                    <div style="font-size:2.5rem; margin-bottom:10px;">📱</div>
                    <h4 style="margin-bottom:10px;">Install BuddyRunner</h4>
                    <p style="font-size:0.9rem; color:var(--txt-dim); margin-bottom:15px;">
                        ${isIOS ? 
                            'Tap Share → Add to Home Screen for best experience!' : 
                            'Install app for notifications & offline access!'}
                    </p>
                    <button onclick="this.parentElement.remove()" class="btn-main" style="padding:12px;">Got it!</button>
                `;
                document.body.appendChild(promptDiv);
                localStorage.setItem('installPromptShown', 'true');
                setTimeout(() => promptDiv.remove(), 8000);
            }, 5000);
        }
    }

    function showNotification(title, body, vibrate = true) {
        if (Notification.permission === "granted") {
            if (vibrate && navigator.vibrate) navigator.vibrate([200, 100, 200]);
            new Notification(title, { 
                body: body,
                icon: 'https://cdn-icons-png.flaticon.com/512/726/726048.png',
                badge: 'https://cdn-icons-png.flaticon.com/512/726/726048.png',
                vibrate: vibrate ? [200, 100, 200] : null
            });
        }
    }

    function loadKarmaCounts() {
        db.collection("users").get().then((snapshot) => {
            snapshot.forEach(doc => {
                userKarmaCounts[doc.id] = doc.data().helps || 0;
            });
            currentUserKarma = userKarmaCounts[currentUserPhone] || 0;
            updateStats();
        });
    }

    function updateStats() {
        const statsCard = document.getElementById('stats-card');
        if (statsCard) {
            statsCard.style.display = 'flex';
            document.getElementById('karma-count').textContent = currentUserKarma;
            document.getElementById('helps-count').textContent = currentUserKarma;
            
            const karmaDetails = getKarmaDetails(currentUserKarma);
            document.getElementById('rank-badge').innerHTML = `${karmaDetails.icon}`;
        }
    }

    function updateUserActiveStatus() {
        if (currentUserPhone) {
            db.collection("activeUsers").doc(currentUserPhone).set({
                name: currentUser,
                lastSeen: Date.now(),
                isRunner: isRunner,
                karmaCount: userKarmaCounts[currentUserPhone] || 0
            }, { merge: true });
        }
    }

    function trackActiveUsers() {
        const tenMinutesAgo = Date.now() - (10 * 60 * 1000);
        db.collection("activeUsers").where("lastSeen", "<", tenMinutesAgo).get().then(snapshot => {
            snapshot.forEach(doc => doc.ref.delete());
        });

        db.collection("activeUsers").onSnapshot(snapshot => {
            activeUsers = snapshot.docs.map(doc => ({ phone: doc.id, ...doc.data() }));
            render();
        });
    }

    function updateKarmaCount(phone) {
        if (!phone) return;
        const userRef = db.collection("users").doc(phone);
        userRef.get().then((doc) => {
            const currentHelps = doc.exists ? (doc.data().helps || 0) : 0;
            userRef.set({ helps: currentHelps + 1, name: currentUser }, { merge: true });
            userKarmaCounts[phone] = currentHelps + 1;
            
            if (phone === currentUserPhone) {
                currentUserKarma = currentHelps + 1;
                updateStats();
                
                // Show level up message
                const oldLevel = getKarmaDetails(currentHelps).title;
                const newLevel = getKarmaDetails(currentHelps + 1).title;
                if (oldLevel !== newLevel) {
                    showNotification("🎉 LEVEL UP!", `You're now a ${newLevel}!`, true);
                }
            }
        });
    }

    function getKarmaDetails(count) {
        if (count >= 50) return { title: "HOSTEL LEGEND", class: "lvl-legend", icon: "👑" };
        if (count >= 25) return { title: "CAMPUS LEGEND", class: "lvl-legend", icon: "⭐" };
        if (count >= 15) return { title: "CAMPUS PRO", class: "lvl-pro", icon: "⚡" };
        if (count >= 8) return { title: "REGULAR", class: "lvl-pro", icon: "✨" };
        if (count >= 3) return { title: "RISING STAR", class: "lvl-pro", icon: "🌟" };
        return { title: "NEWBIE", class: "lvl-newbie", icon: "🌱" };
    }

    db.collection("missions").onSnapshot((snapshot) => {
        const newData = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
        newData.forEach(m => {
            if (m.phone === currentUserPhone && m.runnerAgreed && !handledMatches.has(m.id)) {
                handledMatches.add(m.id);
                showNotification("🎉 Buddy Found!", `${m.rName} accepted your request!`, true);
            }
            if ((m.phone === currentUserPhone || m.rPhone === currentUserPhone) && m.runnerAgreed) {
                setupNotifListener(m.id);
                if (m.id === currentChatId) {
                    document.getElementById('chat-messages').style.backgroundImage = wallpapers[m.wallpaper || 0];
                }
            }
        });
        database = newData;
        processVanishLogic();
        render();
    });

    function setupNotifListener(mid) {
        db.collection("missions").doc(mid).collection("chat").orderBy("time", "desc").limit(1).onSnapshot(s => {
            if(!s.empty) {
                const msg = s.docs[0].data();
                if(msg.phone !== currentUserPhone && mid !== currentChatId) {
                    const bar = document.getElementById('platform-notification');
                    document.getElementById('notif-text').innerText = msg.text;
                    bar.classList.add('show');
                    if(navigator.vibrate) navigator.vibrate([100, 50, 100]);
                    
                    // Also show system notification
                    showNotification("💬 New Message", msg.text, false);
                    
                    setTimeout(() => bar.classList.remove('show'), 4000);
                }
            }
        });
    }

    function processVanishLogic() {
        const now = Date.now();
        database.forEach(m => {
            if (m.expiryTime && now > m.expiryTime) { db.collection("missions").doc(m.id).delete(); }
            if (m.connectedAt && now > (m.connectedAt + (45 * 60 * 1000))) { db.collection("missions").doc(m.id).delete(); }
        });
    }

    function enableNotifications() { 
        if ("Notification" in window) {
            Notification.requestPermission().then(perm => {
                if (perm === "granted") {
                    showNotification("✅ Notifications Enabled", "You'll now get alerts even when app is closed!");
                }
            });
        }
    }

    function saveUser() {
        const name = document.getElementById('u-name').value.trim() || "KAKA RAO👺";
        const phone = document.getElementById('u-phone').value.trim();
        if(phone.length !== 10) return alert("10-digit number required.");
        currentUser = name; currentUserPhone = phone;
        localStorage.setItem('buddyRunnerPhone', phone); localStorage.setItem('buddyRunnerName', name);
        
        db.collection("users").doc(phone).set({ name: name, helps: 0 }, { merge: true });
        trackActiveUsers();
        enableNotifications();
        showApp();
    }

    function quickFill(task, hub) {
        if(document.getElementById('f-task')) document.getElementById('f-task').value = task;
        if(document.getElementById('f-hub')) document.getElementById('f-hub').value = hub;
    }

    function removeMission(id) { 
        if(confirm("Mark as completed? This will add to your karma! ✨")) {
            db.collection("missions").doc(id).get().then(doc => {
                const data = doc.data();
                if (data && data.runnerAgreed && data.rPhone) {
                    updateKarmaCount(data.rPhone);
                    showNotification("✨ Karma +1", `You helped ${data.user}!`, true);
                }
            }).then(() => {
                db.collection("missions").doc(id).delete();
            });
        }
    }

    function logout() { 
        if(confirm("Exit BuddyRunner?")) { 
            if (currentUserPhone) {
                db.collection("activeUsers").doc(currentUserPhone).delete();
            }
            localStorage.clear(); 
            location.reload(); 
        } 
    }

    function showApp() {
        document.getElementById('registration-screen').style.display = 'none';
        document.getElementById('app-body').style.display = 'block';
        document.getElementById('mode-bar').style.display = 'flex';
        document.getElementById('u-display').innerText = currentUser.toUpperCase();
        updateUserActiveStatus();
        updateStats();
        render();
    }

    function setTab(t, offset) { 
        currentTab = t; 
        document.getElementById('glider').style.transform = `translateX(${offset}%)`; 
        render(); 
    }

    function toggleRole() {
        isRunner = !isRunner;
        document.getElementById('role-switch').classList.toggle('active-toggle');
        
        // Update body class for theme
        document.body.classList.toggle('runner-mode', isRunner);
        
        const requesterSection = document.getElementById('requester-section');
        const runnerHeader = document.getElementById('runner-header');
        const feedTitle = document.getElementById('feed-title');
        const activeUsersTitle = document.getElementById('active-users-title');
        const missionFeed = document.getElementById('mission-feed');
        const activeUsersFeed = document.getElementById('active-users-feed');
        
        if (isRunner) {
            // Going Out Mode
            document.getElementById('m-status').innerText = "Going Out Mode";
            document.getElementById('mode-icon').innerText = "🛵";
            document.getElementById('mode-description').innerText = "Available to help others";
            requesterSection.style.display = 'none';
            runnerHeader.style.display = 'block';
            feedTitle.style.display = 'inline';
            activeUsersTitle.style.display = 'none';
            missionFeed.style.display = 'block';
            activeUsersFeed.style.display = 'none';
            
            showNotification("🛵 Going Out Mode", "You're now available to help others!", false);
        } else {
            // Requester Mode
            document.getElementById('m-status').innerText = "Requester Mode";
            document.getElementById('mode-icon').innerText = "🙋";
            document.getElementById('mode-description').innerText = "Ask for help with tasks";
            requesterSection.style.display = 'block';
            runnerHeader.style.display = 'none';
            feedTitle.style.display = 'inline';
            activeUsersTitle.style.display = 'none';
            missionFeed.style.display = 'block';
            activeUsersFeed.style.display = 'none';
        }
        
        updateUserActiveStatus();
        render();
    }

    function syncWallpaper() {
        if(!currentChatId) return;
        const currentM = database.find(m => m.id === currentChatId);
        const nextWall = ((currentM.wallpaper || 0) + 1) % wallpapers.length;
        db.collection("missions").doc(currentChatId).update({ wallpaper: nextWall });
        sendMessage("🎨 Changed chat theme!");
    }

    function postMission() {
        const task = document.getElementById('f-task')?.value || (currentTab === 'ride' ? "Cab Share" : "");
        if(!task) return alert("Please describe what you need help with!");
        
        const h = parseInt(document.getElementById('f-h')?.value) || 0;
        const m = parseInt(document.getElementById('f-m')?.value) || 30;
        const totalMins = (h * 60) + m;
        const reward = document.getElementById('f-reward')?.value || "A Huge Thanks! 🙌";
        
        db.collection("missions").add({
            type: currentTab, 
            hub: document.getElementById('f-hub')?.value || document.getElementById('f-airport')?.value || "Campus",
            task, 
            reward: reward,
            expiryTime: Date.now() + (totalMins * 60 * 1000), 
            user: currentUser, 
            phone: currentUserPhone,
            runnerAgreed: false, 
            rName: "", 
            rPhone: "", 
            connectedAt: null, 
            lat: null, 
            lng: null, 
            wallpaper: 0,
            timestamp: Date.now()
        }).then(() => { 
            showNotification("📢 Request Posted", "Someone will help you soon!", false);
            if(document.getElementById('f-task')) document.getElementById('f-task').value = "";
            render(); 
        });
    }

    function startTracking(id) {
        if ("geolocation" in navigator) {
            navigator.geolocation.watchPosition((pos) => {
                db.collection("missions").doc(id).update({ lat: pos.coords.latitude, lng: pos.coords.longitude });
            }, (err) => console.log(err), { enableHighAccuracy: true });
        }
    }

    function handleHandshake(id) {
        db.collection("missions").doc(id).update({ 
            runnerAgreed: true, rName: currentUser, rPhone: currentUserPhone, connectedAt: Date.now() 
        }).then(() => {
            startTracking(id);
            showNotification("✅ Request Accepted", "You're now helping someone!", true);
        });
    }

    function openChat(missionId, otherPhone) {
        currentChatId = missionId;
        document.getElementById('chat-overlay').style.display = 'flex';
        document.body.style.overflow = 'hidden';
        document.getElementById('call-btn').href = "tel:" + otherPhone;
        const chatBox = document.getElementById('chat-messages');
        if(chatListener) chatListener();
        chatListener = db.collection("missions").doc(missionId).collection("chat").orderBy("time", "asc")
            .onSnapshot(snap => {
                chatBox.innerHTML = '';
                snap.forEach(doc => {
                    const msg = doc.data();
                    const div = document.createElement('div');
                    div.className = `msg ${msg.phone === currentUserPhone ? 'msg-me' : 'msg-them'}`;
                    div.innerText = msg.text;
                    chatBox.appendChild(div);
                });
                chatBox.scrollTop = chatBox.scrollHeight;
            });
    }

    function closeChat() { 
        document.getElementById('chat-overlay').style.display = 'none'; 
        document.body.style.overflow = 'auto'; 
        currentChatId = null; 
        if(chatListener) chatListener(); 
    }

    function sendMessage(customText) {
        const input = document.getElementById('chat-input');
        const text = customText || input.value.trim();
        if(!text || !currentChatId) return;
        db.collection("missions").doc(currentChatId).collection("chat").add({ text, phone: currentUserPhone, time: Date.now() });
        input.value = '';
    }

    function sendNudge() { 
        if(currentChatId) {
            sendMessage("🛎️ NUDGE!");
            if(navigator.vibrate) navigator.vibrate(500);
        }
    }

    function renderActiveUsers() {
        const activeUsersFeed = document.getElementById('active-users-feed');
        if (!activeUsersFeed) return;
        
        activeUsersFeed.innerHTML = '';
        const goingOutUsers = activeUsers.filter(u => u.phone !== currentUserPhone && u.isRunner === true);
        
        if (goingOutUsers.length === 0) {
            activeUsersFeed.innerHTML = '<div class="empty-state"><div class="empty-state-emoji">🛵</div>No one is going out right now.<br>Be the first!</div>';
            return;
        }
        
        goingOutUsers.forEach(user => {
            const karmaDetails = getKarmaDetails(user.karmaCount || 0);
            const minutesAgo = Math.floor((Date.now() - user.lastSeen) / 60000);
            const card = document.createElement('div');
            card.className = 'active-user-card';
            card.innerHTML = `
                <div class="active-user-avatar">${user.name.charAt(0)}</div>
                <div class="active-user-info">
                    <div class="active-user-name">
                        ${user.name}
                        <span class="karma-badge ${karmaDetails.class}">
                            ${karmaDetails.icon} ${karmaDetails.title}
                        </span>
                    </div>
                    <div class="active-user-status">
                        <span class="status-dot"></span>
                        Going Out • ${minutesAgo < 1 ? 'Just now' : `${minutesAgo}m ago`}
                    </div>
                </div>
                <button onclick="openChat('direct_${user.phone}', '${user.phone}')" class="btn-small btn-chat" style="padding:8px 12px;">💬 Chat</button>
            `;
            activeUsersFeed.appendChild(card);
        });
    }

    function render() {
        const form = document.getElementById('form-content');
        if (!form) return;
        
        const scrollTimeHtml = `<div style="display:flex; gap:10px;"><div style="flex:1;"><label>Hours</label><select id="f-h"><option value="0">0</option><option value="1">1</option><option value="2">2</option><option value="3">3</option></select></div><div style="flex:1;"><label>Mins</label><select id="f-m"><option value="0">00</option><option value="15">15</option><option value="30" selected>30</option><option value="45">45</option></select></div></div>`;
        
        if (currentTab === 'errand' && !isRunner) {
            form.innerHTML = `
                <div class="category-grid">
                    <div class="cat-item" onclick="quickFill('📦 Parcel at Gate', '🚪 Main Gate')"><span class="cat-icon">📦</span><span class="cat-label">Parcel</span></div>
                    <div class="cat-item" onclick="quickFill('🍔 Bring Burger', '🏛️ Adda')"><span class="cat-icon">🍔</span><span class="cat-label">Food</span></div>
                    <div class="cat-item" onclick="quickFill('🚬 Need Sutta', '☕ Tapri')"><span class="cat-icon">🚬</span><span class="cat-label">Sutta</span></div>
                    <div class="cat-item" onclick="quickFill('📚 Books from Library', '📖 Library')"><span class="cat-icon">📚</span><span class="cat-label">Books</span></div>
                    <div class="cat-item" onclick="quickFill('💊 Medicine', '🏥 Medical')"><span class="cat-icon">💊</span><span class="cat-label">Medical</span></div>
                    <div class="cat-item" onclick="quickFill('✏️ Stationery', '📝 Store')"><span class="cat-icon">✏️</span><span class="cat-label">Stationery</span></div>
                </div>
                <label>Location</label>
                <select id="f-hub">
                    <option>🚪 Main Gate</option>
                    <option>🏛️ Adda</option>
                    <option>☕ Tapri</option>
                    <option>📖 Library</option>
                    <option>🏥 Medical Store</option>
                    <option>✈️ Shamshabad</option>
                </select>
                
                <label>What do you need?</label>
                <input type="text" id="f-task" placeholder="e.g. Need a pen for the exam" autocomplete="off">
                
                <label>Reward (Non-monetary)</label>
                <select id="f-reward">
                    <option value="A Huge Thanks! 🙌">A Huge Thanks! 🙌</option>
                    <option value="I owe you one! 🤝">I owe you one! 🤝</option>
                    <option value="Coffee on me later ☕">Coffee on me later ☕</option>
                    <option value="A quick snack 🍪">A quick snack 🍪</option>
                    <option value="Eternal Gratitude ✨">Eternal Gratitude ✨</option>
                    <option value="Chai Sutta ☕">Chai Sutta ☕</option>
                    <option value="Maggi Party 🍜">Maggi Party 🍜</option>
                </select>
                
                <label>Request expires in</label>
                ${scrollTimeHtml}
                
                <button onclick="postMission()" class="btn-main">🚀 Broadcast Request</button>`;
        } else if (currentTab === 'ride' && !isRunner) {
            form.innerHTML = `
                <label>Destination</label>
                <select id="f-airport">
                    <option>🛫 RGIA Airport</option>
                    <option>🚂 Secunderabad Station</option>
                    <option>✈️ Shamshabad</option>
                    <option>🏙️ Hi-Tech City</option>
                    <option>🛍️ Inorbit Mall</option>
                </select>
                
                <label>Pickup Pillar #</label>
                <input type="text" id="f-pillar" placeholder="e.g. Pillar 7">
                
                <label>Departure in</label>
                ${scrollTimeHtml}
                
                <label>Share Type</label>
                <select id="f-reward">
                    <option value="Split the fare 🚖">Split the fare 🚖</option>
                    <option value="Coffee on me ☕">Coffee on me ☕</option>
                    <option value="Snacks on me 🍟">Snacks on me 🍟</option>
                    <option value="A Huge Thanks! 🙌">A Huge Thanks! 🙌</option>
                </select>
                
                <button onclick="postMission()" class="btn-main">🚖 Find Cab Partner</button>`;
        }

        const feed = document.getElementById('mission-feed');
        feed.innerHTML = '';
        
        let filtered = [];
        if (isRunner) {
            filtered = database.filter(m => 
                m.type === currentTab && 
                m.phone !== currentUserPhone && 
                !m.runnerAgreed
            );
        } else {
            filtered = database.filter(m => 
                m.type === currentTab && 
                m.phone === currentUserPhone
            );
        }
        
        // Update request count
        document.getElementById('request-count').textContent = filtered.length;
        
        if(filtered.length === 0) {
            if (isRunner) {
                feed.innerHTML = '<div class="empty-state"><div class="empty-state-emoji">🛵</div>No active requests right now.<br>Check back later!</div>';
            } else {
                feed.innerHTML = '<div class="empty-state"><div class="empty-state-emoji">🙋</div>You haven\'t posted any requests.<br>Tap above to ask for help!</div>';
            }
        }

        filtered.forEach(m => {
            const card = document.createElement('div'); 
            card.className = 'mission-card';
            
            const karmaCount = userKarmaCounts[m.user] || 0;
            const karmaDetails = getKarmaDetails(karmaCount);
            
            if(isRunner) {
                // Runner view - show available requests with enhanced UI
                card.innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                    <div class="pill">📍 ${m.hub || 'Campus'}</div>
                    <div class="reward-pill">🎁 ${m.reward || "Gratitude 🙌"}</div>
                </div>
                <div style="font-weight:800; font-size:1.2rem; margin-bottom:12px;">${m.task}</div>
                <div style="font-size:0.85rem; color:var(--txt-dim); margin-bottom:15px; display:flex; align-items:center; justify-content:space-between; background:rgba(255,255,255,0.03); padding:10px; border-radius:12px;">
                    <span>
                        <span style="font-size:1rem;">👤</span> ${m.user}
                        <span class="karma-badge ${karmaDetails.class}" style="margin-left:5px;">
                            ${karmaDetails.icon} ${karmaDetails.title}
                        </span>
                    </span>
                    <span style="background:rgba(255,255,255,0.05); padding:4px 8px; border-radius:8px;">
                        ⏰ ${new Date(m.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                    </span>
                </div>
                <button onclick="handleHandshake('${m.id}')" class="btn-main" style="margin-top:5px;">
                    🚀 I'll Help! (Earn Karma)
                </button>`;
            } else {
                // Requester view - show own requests with enhanced UI
                card.innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                    <div class="pill" style="background:rgba(59,130,246,0.15); color:var(--info);">📋 My Request</div>
                    <div class="reward-pill">🎁 ${m.reward || "Gratitude 🙌"}</div>
                </div>
                <div style="font-weight:800; font-size:1.2rem; margin-bottom:8px;">${m.hub} ➔ ${m.task}</div>
                ${m.runnerAgreed ? `
                <div class="secure-box">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:15px;">
                        <div style="width:40px; height:40px; background:var(--success); border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.2rem;">✅</div>
                        <div style="text-align:left;">
                            <div style="font-weight:800; font-size:1rem;">${m.rName} is helping!</div>
                            <div style="font-size:0.7rem; color:var(--txt-dim);">Connected • Track below</div>
                        </div>
                    </div>
                    ${m.lat ? `<a href="https://www.google.com/maps?q=${m.lat},${m.lng}" target="_blank" class="btn-track">📍 Track Live Location</a>` : ''}
                    <div class="btn-action-row" style="margin-top:15px;">
                        <button onclick="openChat('${m.id}', '${m.phone}')" class="btn-small btn-chat">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                                <path d="M2.678 11.894a1 1 0 0 1 .287.801 11 11 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8 8 0 0 0 8 14c3.996 0 7-2.807 7-6s-3.004-6-7-6-7 2.808-7 6c0 1.462.646 2.793 1.678 3.894m-.493 3.905a22 22 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a10 10 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9 9 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105"/>
                            </svg>
                            Chat
                        </button>
                        <a href="https://wa.me/91${m.phone}" target="_blank" class="btn-small" style="background:#25D366; color:white;">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                                <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.06 3.973L0 16l4.14-1.086A7.98 7.98 0 0 0 7.994 16c4.367 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326z"/>
                            </svg>
                            WhatsApp
                        </a>
                    </div>
                    <button onclick="removeMission('${m.id}')" class="btn-small btn-success" style="margin-top:10px; width:100%;">
                        ✅ Mark Completed (Give Karma)
                    </button>
                </div>` : 
                `<button onclick="removeMission('${m.id}')" class="btn-small btn-cancel" style="margin-top:10px;">
                    ❌ Cancel Request
                </button>`}`;
            }
            feed.appendChild(card);
        });
        
        if (isRunner) {
            renderActiveUsers();
        }
    }
</script>
</body>
</html>
